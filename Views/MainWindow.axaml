<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ContactToVCard.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="ContactToVCard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="400"
        Height="450"
        Title="ContactToVCard">

    <StackPanel Margin="12" Spacing="8">
        <Button Content="{Binding PickFilesText}" Command="{Binding PickFilesCommand}" />
        <TextBlock Text="{Binding SelectedFilesSummary}" TextWrapping="Wrap"/>
        <Button Content="{Binding PickOutputFolderText}" Command="{Binding PickOutputFolderCommand}" />
        <TextBlock Text="{Binding SelectedOutputFolderSummary}" TextWrapping="Wrap"/>
    </StackPanel>
</Window>
